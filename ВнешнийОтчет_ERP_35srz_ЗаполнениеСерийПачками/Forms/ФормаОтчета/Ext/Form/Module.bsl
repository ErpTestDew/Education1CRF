
&НаСервере
Процедура СформироватьНаСервере()
	ОбъектЗначение = РеквизитФормыВЗначение("Отчет");

	СхемаКомпоновкиДанных = ОбъектЗначение.ПолучитьМакет("Макет");
	
	Настройки = Отчет.КомпоновщикНастроек.Настройки;
		
	//Помещаем в переменную данные о расшифровке данных
	ДанныеРасшифровки = Новый ДанныеРасшифровкиКомпоновкиДанных;

	//Формируем макет, с помощью компоновщика макета
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;

	//Передаем в макет компоновки схему, настройки и данные расшифровки
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, Настройки,,,Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	//Выполним компоновку с помощью процессора компоновки
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, , ДанныеРасшифровки);

	//Выводим результат в табличный документ
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ОсновныеДанные = Новый ТаблицаЗначений;
	ПроцессорВывода.УстановитьОбъект(ОсновныеДанные);

	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);   
	Запрос = Новый ЗАпрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	_НомераПачек.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник._НомераПачек КАК _НомераПачек
	|ГДЕ
	|	_НомераПачек.Владелец = &Владелец
	|	И _НомераПачек.Код = &Код";        
	Отчет.ТЧ.Очистить();
	Для каждого СтрокаТЧ из ОсновныеДанные Цикл
		Если СтрДлина(СтрокаТЧ.КодКСУ) < МинимальноеКоличествоСимволов Тогда
			Продолжить;
		КонецЕсли; 
		Если СкладОтделенТире Тогда
			Если СтрНайти(СтрокаТЧ.КодКСУ,"-") > 0 Тогда
				ЧастьСклада = Лев(СтрокаТЧ.КодКСУ,СтрНайти(СтрокаТЧ.КодКСУ,"-")-1);	
				ЧастьБезСклада = Сред(СтрокаТЧ.КодКСУ,СтрДлина(ЧастьСклада)+2);
				ПредполагаемаяПачка = Лев(ЧастьБезСклада,2);
				ОстальнаяЧасть = Сред(ЧастьБезСклада,3);
	           	НоваяСтрокаТЧ = Отчет.ТЧ.Добавить();   
				НоваяСтрокаТЧ.КодКСУ = СтрокаТЧ.КодКСУ; 
				НоваяСтрокаТЧ.ЧастьСтрокиСклада = ЧастьСклада;    
				НоваяСтрокаТЧ.ЧастьСтрокиПачки = ПредполагаемаяПачка; 
				НоваяСтрокаТЧ.ОстальнаяЧасть = ОстальнаяЧасть;   
				Склад = Справочники.Склады.НайтиПоРеквизиту("_КодСклада",ЧастьСклада); 
				НоваяСтрокаТЧ.НайденныйСклад = Склад;   
				Запрос.УстановитьПараметр("Владелец",Склад);
				Запрос.УстановитьПараметр("Код",ПредполагаемаяПачка);
	          	Выборка = Запрос.Выполнить().Выбрать();
				Если Выборка.Следующий() Тогда
					НоваяСтрокаТЧ.НайденнаяПачка = Выборка.Ссылка;  
					НоваяСтрокаТЧ.Отметка = Истина;
				КонецЕсли;
				НоваяСтрокаТЧ.Серия = СтрокаТЧ.Серия;   		
			КонецЕсли;
		Иначе
			Если СтрНайти(СтрокаТЧ.КодКСУ,"-") > 0 Тогда
				ЧастьСклада = Лев(СтрокаТЧ.КодКСУ,СтрНайти(СтрокаТЧ.КодКСУ,"-")-1);	
				ЧастьБезСклада = Сред(СтрокаТЧ.КодКСУ,СтрДлина(ЧастьСклада)+2);
				ПредполагаемаяПачка = Лев(ЧастьБезСклада,2);
				ОстальнаяЧасть = Сред(ЧастьБезСклада,3);
	           	НоваяСтрокаТЧ = Отчет.ТЧ.Добавить();   
				НоваяСтрокаТЧ.КодКСУ = СтрокаТЧ.КодКСУ; 
				НоваяСтрокаТЧ.ЧастьСтрокиСклада = ЧастьСклада;    
				НоваяСтрокаТЧ.ЧастьСтрокиПачки = ПредполагаемаяПачка; 
				НоваяСтрокаТЧ.ОстальнаяЧасть = ОстальнаяЧасть;   
				Склад = Справочники.Склады.НайтиПоРеквизиту("_КодСклада",ЧастьСклада); 
				НоваяСтрокаТЧ.НайденныйСклад = Склад;   
				Запрос.УстановитьПараметр("Владелец",Склад);
				Запрос.УстановитьПараметр("Код",ПредполагаемаяПачка);
	          	Выборка = Запрос.Выполнить().Выбрать();
				Если Выборка.Следующий() Тогда
					НоваяСтрокаТЧ.НайденнаяПачка = Выборка.Ссылка;  
					НоваяСтрокаТЧ.Отметка = Истина;
				КонецЕсли;
				НоваяСтрокаТЧ.Серия = СтрокаТЧ.Серия;   
			Иначе
				
				ЧастьСклада = Лев(СтрокаТЧ.КодКСУ,КоличествоСимволовСклада );	
				ЧастьБезСклада = Сред(СтрокаТЧ.КодКСУ,КоличествоСимволовСклада+1);
				ПредполагаемаяПачка = Лев(ЧастьБезСклада,2);
				ОстальнаяЧасть = Сред(ЧастьБезСклада,3);
	           	НоваяСтрокаТЧ = Отчет.ТЧ.Добавить();   
				НоваяСтрокаТЧ.КодКСУ = СтрокаТЧ.КодКСУ; 
				НоваяСтрокаТЧ.ЧастьСтрокиСклада = ЧастьСклада;    
				НоваяСтрокаТЧ.ЧастьСтрокиПачки = ПредполагаемаяПачка; 
				НоваяСтрокаТЧ.ОстальнаяЧасть = ОстальнаяЧасть;   
				Склад = Справочники.Склады.НайтиПоРеквизиту("_КодСклада",ЧастьСклада); 
				НоваяСтрокаТЧ.НайденныйСклад = Склад;   
				Запрос.УстановитьПараметр("Владелец",Склад);
				Запрос.УстановитьПараметр("Код",ПредполагаемаяПачка);
	          	Выборка = Запрос.Выполнить().Выбрать();
				Если Выборка.Следующий() Тогда
					НоваяСтрокаТЧ.НайденнаяПачка = Выборка.Ссылка;  
					НоваяСтрокаТЧ.Отметка = Истина;
				КонецЕсли;
				НоваяСтрокаТЧ.Серия = СтрокаТЧ.Серия;  
				
			КонецЕсли;	
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура Сформировать(Команда)  
	Элементы.Страницы.ТекущаяСтраница = Элементы.Данные;
	СформироватьНаСервере();
КонецПроцедуры

